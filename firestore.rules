rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function adminEmail() {
      return signedIn() && request.auth.token.email in [
        'mhmd1212@gmail.com',
        'mhmdhaffi42@gmail.com'
      ];
    }
    function signedIn() {
      return request.auth != null;
    }
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    function hasUserDoc() {
      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    function role() {
      return hasUserDoc() ? userDoc().data.role : '';
    }
    function isAdmin() {
      return role() == 'admin' && adminEmail();
    }
    function isDeveloper() {
      return role() == 'developer' || isAdmin();
    }
    function validRole(value) {
      return value in ['customer', 'developer', 'admin'];
    }
    function validStatus(value) {
      return value in ['pending', 'accepted', 'done', 'closed'];
    }
    function validUserCreate(uid) {
      return request.auth.uid == uid
        && request.resource.data.uid == uid
        && request.resource.data.email == request.auth.token.email
        && validRole(request.resource.data.role)
        && (request.resource.data.role != 'admin' || adminEmail());
    }
    function validUserUpdate(uid) {
      return request.auth.uid == uid
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && validRole(request.resource.data.role)
        && (
          request.resource.data.role == resource.data.role ||
          (request.resource.data.role == 'admin' && adminEmail())
        );
    }
    function validProjectCreate() {
      return isAdmin() || (
        role() == 'customer'
        && request.resource.data.keys().hasOnly([
          'customerId',
          'customerName',
          'customerEmail',
          'title',
          'siteType',
          'budget',
          'deadline',
          'referenceUrl',
          'description',
          'status',
          'acceptedDeveloperId',
          'acceptedDeveloperName',
          'chatId',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.customerId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.acceptedDeveloperId == ''
        && request.resource.data.acceptedDeveloperName == ''
        && request.resource.data.chatId == ''
      );
    }
    function validProjectAccept(projectId) {
      return isDeveloper()
        && resource.data.status == 'pending'
        && resource.data.acceptedDeveloperId == ''
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'acceptedDeveloperId',
          'acceptedDeveloperName',
          'acceptedAt',
          'chatId',
          'updatedAt'
        ])
        && request.resource.data.status == 'accepted'
        && request.resource.data.acceptedDeveloperId == request.auth.uid
        && request.resource.data.chatId == 'project_' + projectId;
    }
    function validProjectStatusUpdate() {
      return validStatus(request.resource.data.status)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'updatedAt',
          'updatedBy'
        ])
        && (isAdmin() || resource.data.acceptedDeveloperId == request.auth.uid);
    }
    function chatDoc(chatId) {
      return get(/databases/$(database)/documents/chats/$(chatId));
    }
    function isChatParticipant(chatId) {
      return signedIn() && (
        isAdmin() ||
        request.auth.uid in chatDoc(chatId).data.participants
      );
    }

    match /users/{uid} {
      allow create: if signedIn() && validUserCreate(uid);
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow update: if signedIn() && (validUserUpdate(uid) || isAdmin());
      allow delete: if false;
    }

    match /projects/{projectId} {
      allow create: if signedIn() && validProjectCreate();
      allow read: if signedIn() && (
        resource.data.customerId == request.auth.uid ||
        resource.data.acceptedDeveloperId == request.auth.uid ||
        (isDeveloper() && resource.data.status == 'pending' && resource.data.acceptedDeveloperId == '') ||
        isAdmin()
      );
      allow update: if signedIn() && (
        isAdmin() ||
        validProjectAccept(projectId) ||
        validProjectStatusUpdate()
      );
      allow delete: if isAdmin();
    }

    match /chats/{chatId} {
      allow create: if signedIn() && (
        isAdmin() ||
        (
          chatId == 'project_' + request.resource.data.projectId
          && request.auth.uid in request.resource.data.participants
          && exists(/databases/$(database)/documents/projects/$(request.resource.data.projectId))
          && request.resource.data.keys().hasOnly([
            'projectId',
            'customerId',
            'developerId',
            'participants',
            'createdAt',
            'updatedAt'
          ])
          && request.resource.data.participants.size() == 2
          && get(/databases/$(database)/documents/projects/$(request.resource.data.projectId)).data.status in ['accepted', 'done', 'closed']
          && get(/databases/$(database)/documents/projects/$(request.resource.data.projectId)).data.customerId == request.resource.data.customerId
          && get(/databases/$(database)/documents/projects/$(request.resource.data.projectId)).data.acceptedDeveloperId == request.resource.data.developerId
          && get(/databases/$(database)/documents/projects/$(request.resource.data.projectId)).data.customerId in request.resource.data.participants
          && get(/databases/$(database)/documents/projects/$(request.resource.data.projectId)).data.acceptedDeveloperId in request.resource.data.participants
        )
      );
      allow read: if signedIn() && (request.auth.uid in resource.data.participants || isAdmin());
      allow update: if signedIn()
        && (request.auth.uid in resource.data.participants || isAdmin())
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'updatedAt',
          'lastMessage'
        ]);
      allow delete: if isAdmin();

      match /messages/{msgId} {
        allow read: if isChatParticipant(chatId);
        allow create: if isChatParticipant(chatId)
          && request.resource.data.fromUid == request.auth.uid
          && request.resource.data.keys().hasOnly([
            'fromUid',
            'fromName',
            'message',
            'attachment',
            'createdAt'
          ]);
        allow update, delete: if false;
      }
    }
  }
}
